# HushCircuits Pro v2

# ========== AUTH ==========
JWT_SECRET=change-me-in-prod
JWT_EXPIRY_HOURS=24

# ========== DATABASE (PostgreSQL) ==========
DATABASE_URL=postgres://postgres:postgres@localhost:5433/hushcircuits?sslmode=disable

# ========== REDIS ==========
REDIS_URL=redis://localhost:6380/0

# ========== SUPABASE (Optional - leave empty for demo/HMAC mode) ==========
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ========== SIP TELEPHONY ==========
SIP_HOST=sip.sipup.org
SIP_PORT=5060
SIP_USERNAME=
SIP_PASSWORD=
SIP_TRANSPORT=udp
SIP_DISPLAY_NAME=HushCircuits
SIP_CALLER_ID=

# ========== EXTERNAL APIs (set to "demo" for mock mode) ==========
GENSMS_API_KEY=demo
FEATHERLESS_API_KEY=demo
FEATHERLESS_MODEL=captain-eris-violet-12b
FEATHERLESS_PROMPT=
CNAM_API_KEY=

# ========== NOW PAYMENTS (Crypto Checkout) ==========
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_CALLBACK_URL=http://localhost:8080/api/webhooks/nowpayments

# ========== TOKEN SERVICE ==========
TOKEN_RATE=0.50
VIP_PRICE=250.00
VIP_DURATION_DAYS=7
OTP_GRAB_COST_USD=5.00
OTP_GRAB_TOKENS=10
OTP_GRAB_CALL_COST_USD=2.50
OTP_GRAB_CALL_TOKENS=5

# ========== CORS ==========
ALLOWED_ORIGINS=http://localhost:3000

# ========== LOGGING ==========
LOG_LEVEL=info

# ========== ADMIN ==========
ADMIN_EMAIL=admin@hushcircuits.io
